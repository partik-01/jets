datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String?
  role      String     @default("USER") // USER, ADMIN
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
  auditLogs AuditLog[]
}

model Manufacturer {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  country     String?
  description String?
  foundedYear Int?
  aircrafts   Aircraft[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Country {
  id        String     @id @default(uuid())
  name      String     @unique
  code      String     @unique // e.g., "US", "RU", "FR", "GB", "CN", "JP"
  region    String?    // e.g., "North America", "Europe", "Asia"
  flagIcon  String?
  aircrafts Aircraft[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  bannerImage String?
  aircrafts   Aircraft[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Aircraft {
  id                    String            @id @default(uuid())
  name                  String
  slug                  String            @unique
  role                  String
  generation            String?           // e.g. "4th Gen", "5th Gen"
  introductionDate      DateTime?
  status                String            @default("Active") // Active, Retired, In Development
  firstFlight           DateTime?
  cost                  String?           // Text to support formatted price (e.g. "$150 Million")
  crew                  String?
  description           String
  historicalSignificance String?
  prodNumbers           Int?
  featured              Boolean           @default(false)
  ofTheDay              Boolean           @default(false)
  latestAddition        Boolean           @default(false)
  
  manufacturerId        String
  manufacturer          Manufacturer      @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  
  countryId             String
  country               Country           @relation(fields: [countryId], references: [id], onDelete: Cascade)
  
  categoryId            String
  category              Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  specifications        Specification?
  images                AircraftImage[]
  models                Model3D[]
  favorites             Favorite[]
  references            Reference[]
  timelineEvents        TimelineEvent[]
  tags                  Tag[]
  
  relatedFrom           RelatedAircraft[] @relation("relatedFrom")
  relatedTo             RelatedAircraft[] @relation("relatedTo")
  
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model RelatedAircraft {
  fromId String
  toId   String
  from   Aircraft @relation("relatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Aircraft @relation("relatedTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
}

model Specification {
  id             String   @id @default(uuid())
  aircraftId     String   @unique
  aircraft       Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  
  // Dimensions
  length         String?
  wingspan       String?
  height         String?
  
  // Weights
  emptyWeight    String?
  maxTakeoffWeight String?
  fuelCapacity   String?
  
  // Performance
  maxSpeed       String?
  cruiseSpeed    String?
  range          String?
  combatRadius   String?
  serviceCeiling String?
  rateOfClimb    String?
  
  // Propulsion
  engineName     String?
  engineType     String?
  engineCount    Int?
  thrustPerEngine String?
  totalThrust    String?
  
  // Avionics
  radarSystem    String?
  glassCockpit   String?
  displaySystems String?
  otherAvionics  String?
  
  // Armament
  gunSystem      String?
  hardpointsCount Int?
  weaponsCapacity String?
  weaponsDescription String?
}

model AircraftImage {
  id         String   @id @default(uuid())
  aircraftId String
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Model3D {
  id         String   @id @default(uuid())
  aircraftId String
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  url        String
  format     String   @default("glb") // glb or gltf
  fileSize   String?
  scale      Float    @default(1.0)
  positionX  Float    @default(0.0)
  positionY  Float    @default(0.0)
  positionZ  Float    @default(0.0)
  rotationX  Float    @default(0.0)
  rotationY  Float    @default(0.0)
  rotationZ  Float    @default(0.0)
  createdAt  DateTime @default(now())
}

model TimelineEvent {
  id          String    @id @default(uuid())
  decade      String    // e.g. "1950s", "1960s"
  year        Int
  title       String
  description String
  aircraftId  String?
  aircraft    Aircraft? @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  aircrafts Aircraft[]
}

model Reference {
  id         String   @id @default(uuid())
  aircraftId String
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  title      String
  url        String
  createdAt  DateTime @default(now())
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aircraftId String
  aircraft   Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, aircraftId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String   // CREATE_AIRCRAFT, UPDATE_AIRCRAFT, DELETE_AIRCRAFT
  entityType String   // Aircraft
  entityId   String
  details    String?
  timestamp  DateTime @default(now())
}
